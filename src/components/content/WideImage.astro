---
interface Props {
  src: string;
  alt?: string;
  caption?: string;
}

const { src, alt = '', caption } = Astro.props;
---

<figure class="wide-image">
  <img src={src} alt={alt} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .wide-image {
    width: min(100vw - 48px, var(--wide));
    margin: 2.4em 50% 2.1em;
    transform: translateX(-50%);
  }

  .wide-image img {
    width: 100%;
    max-height: 680px;
    object-fit: cover;
    border: 1px solid var(--line);
  }

  .wide-image figcaption {
    max-width: var(--content);
    margin: 10px auto 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.7;
  }
</style>
