---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<aside class="note-block">
  {title && <h4>{title}</h4>}
  <slot />
</aside>

<style>
  .note-block {
    margin: 2em 0;
    padding: 18px 20px;
    border: 1px solid var(--line);
    background: rgba(79, 117, 98, 0.06);
    color: var(--muted);
  }

  .note-block h4 {
    margin: 0 0 8px;
    color: var(--ink);
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 650;
  }
</style>
