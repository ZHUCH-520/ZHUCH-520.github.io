---
interface ImageItem {
  src: string;
  alt?: string;
  caption?: string;
}

interface Props {
  images: [ImageItem, ImageItem];
}

const { images } = Astro.props;
---

<div class="image-pair">
  {images.map((image) => (
    <figure>
      <img src={image.src} alt={image.alt ?? ''} loading="lazy" />
      {image.caption && <figcaption>{image.caption}</figcaption>}
    </figure>
  ))}
</div>

<style>
  .image-pair {
    width: min(100vw - 48px, 960px);
    margin: 2.2em 50%;
    transform: translateX(-50%);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .image-pair figure {
    margin: 0;
  }

  .image-pair img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: 1px solid var(--line);
  }

  .image-pair figcaption {
    margin-top: 8px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.65;
  }

  @media (max-width: 680px) {
    .image-pair {
      grid-template-columns: 1fr;
    }
  }
</style>
