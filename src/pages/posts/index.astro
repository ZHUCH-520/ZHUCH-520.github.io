---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/layout/PostCard.astro';
import { getTagCounts, getVisiblePosts } from '../../lib/post-utils';

const posts = getVisiblePosts(await getCollection('posts'));
const tags = getTagCounts(posts);
---

<BaseLayout title="全部文章" description="Reid's Notes 的完整文章归档。">
  <section class="section">
    <p class="eyebrow">Archive</p>
    <h1 class="display-title">全部文章</h1>
    <p class="display-copy">按时间排列的完整归档。草稿不会出现在这里。</p>
    <div class="tag-list">
      {tags.map(([tag, count]) => (
        <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>{tag} · {count}</a>
      ))}
    </div>
  </section>
  <section class="section">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
