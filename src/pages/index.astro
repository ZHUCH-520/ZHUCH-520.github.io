---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Reid's Notes" description="在生活和技术之间，慢慢写。不放弃思考，不交出自己。">
  <section class="home-cover section">
    <div class="home-cover__statement">
      <h1 class="display-title">在生活和技术之间，慢慢写。</h1>
      <p class="home-cover__line article-serif">不放弃思考，不交出自己。</p>
    </div>
    <figure class="whole-earth-cover">
      <img
        src="/images/whole-earth-stay-hungry.jpg"
        alt="Whole Earth Catalog 最后一期封底，写有 Stay Hungry. Stay Foolish."
        width="700"
        height="953"
      />
      <figcaption>
        Photo by <a href="https://www.flickr.com/photos/tracilawson/6216133338">Traci Lawson</a>,
        licensed under <a href="https://creativecommons.org/licenses/by/2.0/">CC BY 2.0</a>.
      </figcaption>
    </figure>
  </section>
</BaseLayout>

<style>
  .home-cover {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 340px);
    gap: 72px;
    align-items: start;
    min-height: calc(100vh - 156px);
    padding-top: 92px;
  }

  .home-cover__statement {
    display: grid;
    gap: 34px;
  }

  .home-cover__statement .display-title {
    max-width: 720px;
    margin: 0;
    font-size: clamp(48px, 7.2vw, 86px);
    line-height: 1.06;
  }

  .home-cover__line {
    max-width: 420px;
    margin: 0;
    padding-left: 18px;
    border-left: 1px solid var(--line);
    color: var(--muted);
    font-size: 21px;
    line-height: 1.85;
  }

  .whole-earth-cover {
    width: min(100%, 340px);
    justify-self: end;
    margin: 0;
    margin-top: 72px;
  }

  .whole-earth-cover img {
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    background: var(--paper-strong);
  }

  .whole-earth-cover figcaption {
    margin-top: 10px;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.5;
  }

  @media (max-width: 820px) {
    .home-cover {
      grid-template-columns: 1fr;
      gap: 32px;
      min-height: auto;
      padding-top: 56px;
    }

    .home-cover__statement {
      gap: 26px;
    }

    .home-cover__line {
      max-width: 360px;
      font-size: 19px;
    }

    .whole-earth-cover {
      width: min(78vw, 320px);
      justify-self: start;
      margin-top: 18px;
    }
  }
</style>
