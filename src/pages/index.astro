---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Reid's Notes" description="在生活和技术之间，慢慢写。不放弃思考，不交出自己。">
  <section class="home-cover section">
    <div class="home-cover__statement">
      <h1 class="display-title">在生活和技术之间，慢慢写。</h1>
      <p class="home-cover__line article-serif">不放弃思考，不交出自己。</p>
    </div>
    <figure class="whole-earth-cover">
      <img
        src="/images/whole-earth-stay-hungry.jpg"
        alt="Whole Earth Catalog 最后一期封底，写有 Stay Hungry. Stay Foolish."
        width="700"
        height="953"
      />
      <figcaption>
        Photo by <a href="https://www.flickr.com/photos/tracilawson/6216133338">Traci Lawson</a>,
        licensed under <a href="https://creativecommons.org/licenses/by/2.0/">CC BY 2.0</a>.
      </figcaption>
    </figure>
  </section>
</BaseLayout>

<style>
  .home-cover {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 56px;
    align-items: center;
    min-height: calc(100vh - 160px);
  }

  .home-cover__statement {
    display: grid;
    gap: 26px;
  }

  .home-cover__statement .display-title {
    max-width: 760px;
    margin: 0;
  }

  .home-cover__line {
    max-width: 560px;
    margin: 0;
    color: var(--blue-ink);
    font-size: 30px;
    line-height: 1.65;
  }

  .whole-earth-cover {
    margin: 0;
  }

  .whole-earth-cover img {
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    background: var(--paper-strong);
  }

  .whole-earth-cover figcaption {
    margin-top: 10px;
    color: var(--muted);
    font-size: 12px;
    line-height: 1.5;
  }

  @media (max-width: 820px) {
    .home-cover {
      grid-template-columns: 1fr;
      gap: 32px;
      min-height: auto;
      padding-top: 48px;
    }

    .home-cover__line {
      font-size: 24px;
    }
  }
</style>
