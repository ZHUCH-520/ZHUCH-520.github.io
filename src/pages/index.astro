---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Reid's Notes" description="在生活和技术之间，慢慢写。不放弃思考，不交出自己。">
  <section class="home-cover section">
    <div class="home-cover__statement">
      <h1 class="display-title">在生活和技术之间，慢慢写。</h1>
      <p class="home-cover__line article-serif">不放弃思考，不交出自己。</p>
    </div>
    <figure class="earthrise-cover">
      <img
        src="/images/earthrise-apollo8.jpg"
        alt="Apollo 8 从月球附近拍摄的地球升起照片"
        width="2400"
        height="2400"
      />
      <figcaption>
        NASA Apollo 8 / Earthrise, AS08-14-2383. Used on the Spring 1969 Whole Earth Catalog cover.
      </figcaption>
    </figure>
  </section>
</BaseLayout>

<style>
  .home-cover {
    position: relative;
    min-height: calc(100vh - 156px);
    display: grid;
    align-items: end;
    overflow: hidden;
    padding-top: 72px;
    padding-bottom: 78px;
  }

  .home-cover__statement {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 30px;
    max-width: 700px;
    padding-bottom: 18px;
  }

  .home-cover__statement .display-title {
    max-width: 700px;
    margin: 0;
    font-size: clamp(52px, 7.4vw, 90px);
    line-height: 1.06;
  }

  .home-cover__line {
    max-width: 360px;
    margin: 0;
    padding-top: 20px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 21px;
    line-height: 1.85;
  }

  .earthrise-cover {
    position: absolute;
    inset: 0 0 0 auto;
    width: 54%;
    margin: 0;
    overflow: hidden;
    border-left: 1px solid var(--line);
  }

  .earthrise-cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(247, 243, 234, 0.94), rgba(247, 243, 234, 0.18) 54%, rgba(247, 243, 234, 0));
    pointer-events: none;
  }

  .earthrise-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    background: #050505;
  }

  .earthrise-cover figcaption {
    position: absolute;
    right: 18px;
    bottom: 16px;
    z-index: 1;
    max-width: 280px;
    color: rgba(255, 255, 255, 0.68);
    font-size: 12px;
    line-height: 1.5;
    text-align: right;
  }

  @media (max-width: 820px) {
    .home-cover {
      min-height: auto;
      padding-top: 48px;
      padding-bottom: 52px;
    }

    .home-cover__statement {
      gap: 24px;
      padding-bottom: 0;
    }

    .home-cover__line {
      max-width: 340px;
      font-size: 19px;
    }

    .earthrise-cover {
      position: relative;
      inset: auto;
      width: 100%;
      height: 360px;
      order: 2;
      margin-top: 38px;
      border: 1px solid var(--line);
    }

    .earthrise-cover::after {
      display: none;
    }

    .earthrise-cover figcaption {
      right: 14px;
      bottom: 12px;
    }
  }
</style>
