---
import '../styles/global.css';
import { site } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const pageTitle = title === site.title ? title : `${title} · ${site.name}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} RSS`} href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="site-brand" href="/">{site.name}</a>
          <nav class="site-nav" aria-label="主导航">
            {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
        </div>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer__inner">
          <span>© {new Date().getFullYear()} {site.author}</span>
          <span>Built with Astro · Hosted on GitHub Pages</span>
        </div>
      </footer>
    </div>
  </body>
</html>
