---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { formatPostDate } from '../lib/post-utils';
import { categoryLabels } from '../lib/site';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="article-page">
    <header class="article-hero">
      <div>
        <p class="eyebrow">{categoryLabels[post.data.category]} / {formatPostDate(post.data.date)}</p>
        <h1>{post.data.title}</h1>
      </div>
      <div>
        <div class="article-hero__meta">
          {post.data.location && <span>{post.data.location} · </span>}
          <span>{post.data.tags.join(' / ')}</span>
        </div>
        <p class="article-hero__summary">{post.data.description}</p>
      </div>
    </header>
    {post.data.cover && (
      <figure class="article-cover">
        <img src={post.data.cover} alt="" loading="eager" />
      </figure>
    )}
    <div class="article-content">
      <slot />
    </div>
  </article>
</BaseLayout>
